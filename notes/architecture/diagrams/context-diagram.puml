@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Context.puml

LAYOUT_WITH_LEGEND()

title System Context Diagram for Backstage

' People
Person(developer, "Developer", "Builds and owns services. Browses the catalog, scaffolds new projects, and reads TechDocs.")
Person(platform_eng, "Platform Engineer", "Configures, extends, and maintains the Backstage instance. Installs plugins and manages integrations.")
Person(eng_manager, "Engineering Manager", "Monitors service ownership, team structure, and system health.")

' Software System
System(backstage, "Backstage", "Open developer portal framework providing a unified interface for software catalog, documentation, and project scaffolding.")

' External Systems
System_Ext(source_control, "Source Control", "GitHub / GitLab. Stores source code and catalog-info.yaml files.")
System_Ext(cicd, "CI/CD System", "Jenkins / GitHub Actions. Executes build and deployment pipelines.")
System_Ext(cloud_infra, "Cloud Infrastructure", "Kubernetes / AWS / GCP. Runs the actual services and workloads.")
System_Ext(idp, "Identity Provider", "Okta / GitHub OAuth. Manages user authentication and group resolution.")

' User Relationships
Rel(developer, backstage, "Browses catalog, scaffolds projects, reads docs", "HTTPS")
Rel(platform_eng, backstage, "Installs plugins and configures system", "HTTPS / CLI")
Rel(eng_manager, backstage, "Monitors teams and services", "HTTPS")

' System Relationships
Rel(backstage, source_control, "Reads catalog-info.yaml, creates repositories", "REST API / HTTPS")
Rel(backstage, cicd, "Fetches build and pipeline status", "REST API / HTTPS")
Rel(backstage, cloud_infra, "Queries cluster state", "REST API / HTTPS")
Rel(backstage, idp, "Authenticates users and resolves groups", "OAuth2 / HTTPS")

@enduml

@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Context.puml

LAYOUT_WITH_LEGEND()

title System Context Diagram for Backstage

' People [cite: 985]
Person(developer, "Developer", "Builds and owns services using the portal.")
Person(platform_eng, "Platform Engineer", "Configures, extends, and maintains the portal framework.")
Person(eng_manager, "Engineering Manager", "Monitors team progress and service health.")

' Software System [cite: 309, 1037]
System(backstage, "Backstage", "Open developer portal framework providing a unified interface for software catalog, docs, and scaffolding.")

' External Systems [cite: 986]
System_Ext(source_control, "Source Control", "GitHub / GitLab. Stores source code and catalog-info.yaml files.")
System_Ext(cicd, "CI/CD System", "Jenkins / GitHub Actions. Executes build and deployment pipelines.")
System_Ext(cloud_infra, "Cloud Infrastructure", "Kubernetes / AWS / GCP. Runs the actual services and workloads.")
System_Ext(idp, "Identity Provider", "Okta / GitHub OAuth. Manages user authentication and authorization.")

' Relationships [cite: 988, 989]
Rel(developer, backstage, "Browses catalog and uses templates")
Rel(platform_eng, backstage, "Installs plugins and configures system")
Rel(eng_manager, backstage, "Monitors teams and services")

Rel(backstage, source_control, "Reads catalog-info.yaml and creates repositories")
Rel(backstage, cicd, "Fetches build status")
Rel(backstage, cloud_infra, "Queries cluster state")
Rel(backstage, idp, "Authenticates users")

@enduml